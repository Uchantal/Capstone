MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/dcip?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here
PORT=5000
CLIENT_URL=http://YOUR_DROPLET_IP
FRONTEND_URL=http://YOUR_DROPLET_IP
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password

# Cloudinary — file storage for studio works (images + audio)
# Get these from cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
